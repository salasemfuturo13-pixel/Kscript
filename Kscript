/*
    KScript V1.0 - Desenvolvido por JK
    Tema: Black & Red Edition
    Compatível: Khan Academy
*/

(async function() {
    const ver = "V1.0";
    let isDev = false;

    // --- CONFIGURAÇÕES JK ---
    const logoUrl = "https://github.com/salasemfuturo13-pixel/Kscript/blob/main/logo.png?raw=true";
    const repoPathDefault = `https://raw.githubusercontent.com/nickzplayerzx/KhanScript/${isDev ? "dev" : "main"}/`;

    let user = { nickname: "Estudante", username: "User", UID: 0 };
    let loadedPlugins = [];
    const splashScreen = document.createElement('div');

    // Funções de Utilidade
    const delay = ms => new Promise(resolve => setTimeout(resolve, ms));
    
    // --- ESTILIZAÇÃO CSS (SOBRESCREVENDO O ROXO) ---
    const styleElement = document.createElement("style");
    styleElement.innerHTML = `
        /* Scrollbar Personalizada */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #000000; }
        ::-webkit-scrollbar-thumb { background: #ff0000; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #b30000; }

        /* ESTILO DO MENU KSCRIPT (FORÇADO BLACK & RED) */
        #menu-container, [id*="menu"], .main-menu, [class*="Menu"] { 
            background: rgba(0, 0, 0, 0.95) !important; 
            border: 2px solid #ff0000 !important;
            box-shadow: 0 0 25px rgba(255, 0, 0, 0.5) !important;
            border-radius: 15px !important;
            color: white !important;
        }

        /* Títulos e Textos */
        h1, h2, .menu-title, [id*="title"] {
            color: #ff0000 !important;
            text-shadow: 0 0 10px #ff0000 !important;
        }

        /* Toggles / Interruptores */
        input:checked + .slider, .switch input:checked + div {
            background-color: #ff0000 !important;
        }
        
        input:checked + .slider:before, .switch input:checked + div:before {
            background-color: #ffffff !important;
        }

        /* Painel de Status Inferior */
        #status-panel, [id*="stats"], [class*="Status"] {
            background: #000000 !important;
            border-top: 3px solid #ff0000 !important;
            box-shadow: 0 -5px 15px rgba(255, 0, 0, 0.3) !important;
            color: #ffffff !important;
        }

        [id*="stats"] span, .stat-value {
            color: #ff0000 !important;
            font-weight: bold !important;
        }

        /* Créditos no Menu/Painel */
        .watermark, [id*="credit"], .credits {
            color: #ff0000 !important;
            font-family: 'Arial', sans-serif !important;
        }
        
        /* Toastify Customizado */
        .toastify {
            background: linear-gradient(to right, #000000, #ff0000) !important;
            color: white !important;
            border: 1px solid #ff0000 !important;
            border-radius: 10px !important;
        }
    `;
    document.head.appendChild(styleElement);

    // --- FUNÇÕES DE INTERFACE ---
    function sendToast(text, duration = 3000) {
        if (window.Toastify) {
            Toastify({
                text: text,
                duration: duration,
                gravity: "bottom",
                position: "center"
            }).showToast();
        }
    }

    async function showSplashScreen() {
        splashScreen.style.cssText = `
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: radial-gradient(circle, #330000 0%, #000000 100%);
            display: flex; align-items: center; justify-content: center;
            z-index: 10000; color: white; font-family: sans-serif;
            flex-direction: column; transition: opacity 0.5s ease;
        `;
        splashScreen.innerHTML = `
            <img src="${logoUrl}" style="height:120px; filter: drop-shadow(0 0 15px #ff0000); margin-bottom: 20px;">
            <h1 style="color:#ff0000; font-size:40px; margin:0; text-shadow: 0 0 15px #ff0000;">KSCRIPT</h1>
            <p style="letter-spacing: 3px; font-weight: bold; color: #888;">BY JK</p>
        `;
        document.body.appendChild(splashScreen);
        await delay(100);
        splashScreen.style.opacity = "1";
    }

    // --- INICIALIZAÇÃO ---
    if (!location.href.includes("khanacademy.org")) {
        alert("Acesse a Khan Academy primeiro!");
        return;
    }

    await showSplashScreen();

    // Carregar Dependências
    const loadScript = (url, label) => {
        return fetch(url).then(r => r.text()).then(code => {
            // Pequeno Hack para mudar o crédito de quem criou o menu dinamicamente
            const modifiedCode = code.replace(/Nickz/g, "JK").replace(/KhanScript/g, "KScript");
            eval(modifiedCode);
            loadedPlugins.push(label);
        }).catch(() => console.error("Falha ao carregar: " + label));
    };

    // Plugins Essenciais
    await loadScript('https://cdn.jsdelivr.net/npm/toastify-js', 'Notificações');
    const toastStyle = document.createElement('link');
    toastStyle.rel = 'stylesheet'; toastStyle.href = 'https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css';
    document.head.appendChild(toastStyle);

    // Carregando Módulos do Menu e Funções
    await loadScript(repoPathDefault + 'visuals/mainMenu.js', 'Menu');
    await loadScript(repoPathDefault + 'visuals/statusPanel.js', 'Stats');
    await loadScript(repoPathDefault + 'functions/questionSpoof.js', 'Resolver');
    await loadScript(repoPathDefault + 'functions/videoSpoof.js', 'Video');
    await loadScript(repoPathDefault + 'functions/answerRevealer.js', 'Revealer');

    // Pega o nome do usuário na Khan
    fetch("https://pt.khanacademy.org/api/internal/graphql/getFullUserProfile", {
        method: "POST",
        body: '{"operationName":"getFullUserProfile","query":"query getFullUserProfile { user { nickname } }"}'
    }).then(r => r.json()).then(d => {
        if(d.data?.user) user.nickname = d.data.user.nickname;
    });

    // Finalização
    setTimeout(() => {
        splashScreen.style.opacity = "0";
        setTimeout(() => splashScreen.remove(), 500);
        
        sendToast(`KScript ${ver} Carregado!`);
        setTimeout(() => sendToast(`Bem-vindo, ${user.nickname} [JK Version]`), 1000);
        
        console.clear();
        console.log("%c KSCRIPT BY JK %c Status: Online ", "background:#ff0000; color:#000; font-size:20px; font-weight:bold;", "background:#000; color:#ff0000; font-size:20px;");
    }, 2500);

})();
